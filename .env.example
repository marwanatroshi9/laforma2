# Database
POSTGRES_USER=arch
POSTGRES_PASSWORD=arch
POSTGRES_DB=arch_platform

# Backend
SECRET_KEY=please-change-this-to-a-long-random-string
BACKEND_CORS_ORIGINS=http://localhost:3000
FIRST_ADMIN_EMAIL=admin@studio.com
FIRST_ADMIN_PASSWORD=admin1234

# Email notifications (optional — leave blank to disable)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@studio.com
SMTP_TLS=true
NOTIFY_EMAIL=

# Production HTTPS (used by docker-compose.prod.yml / Caddy)
DOMAIN=yourstudio.com
ACME_EMAIL=you@yourstudio.com

# Frontend
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Analytics (optional — set one to enable; leave blank to disable)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_GA_ID=
